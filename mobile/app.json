{
  "expo": {
    "name": "Lumen",
    "slug": "lumen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lumen",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lumen.app"
    },
    "android": {
      "package": "com.lumen.app",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b6d82d98-6a6a-4d1b-98b5-11b9b616f1c6"
      }
    }
  }
}